"""
Disk image build configuration.
"""

import os
import shutil
import subprocess
from pathlib import Path

from SCons.Action import Action
from SCons.Environment import Environment
from SCons.Script import Flatten

from scripts.scons.utility import GlobRecursive
from scripts.scons.disk import (
    VolumeLabel,
    CreateBootableIso,
    GenerateGrubConfig,
)

Import("Kernel")
Import("UserLibraries")
Import("UserApplications")
Import("TargetEnvironment")

TargetEnvironment: Environment
Env: Environment = TargetEnvironment


def IterBootloaderComponentNodes(Components: dict):
    for ComponentName, Component in Components.items():
        if hasattr(Component, "get_abspath"):
            yield ComponentName, Component
            continue

        for Item in Flatten([Component]):
            if not hasattr(Item, "get_abspath"):
                continue
            ItemName = f"{ComponentName}:{os.path.basename(str(Item))}"
            yield ItemName, Item


def BuildDisk(
    ImagePath,
    KernelExecutablePath,
    Libraries,
    Applications,
    ExtraFiles,
    BootloaderComponents,
    EnvironmentObject,
):
    Architecture = EnvironmentObject.get("BuildArch", "i686")
    BootType = EnvironmentObject.get("BootType", "bios")
    BootSystem = EnvironmentObject.get("BootSystem", "grub")
    BuildConfig = EnvironmentObject.get("BuildConfig", "release")

    Volume = VolumeLabel

    BuildTag = f"{Architecture}_{BuildConfig}"
    Stage = EnvironmentObject.get(
        "ImageStagingDirectory", os.path.join("build", BuildTag, "img")
    )

    if os.path.isdir(Stage):
        shutil.rmtree(Stage)
    elif os.path.exists(Stage):
        os.remove(Stage)

    os.makedirs(Stage, exist_ok=True)

    print(f"   STAGE -> {Stage}")

    Compiler = EnvironmentObject.subst("$CC")
    try:
        RuntimeSysroot = subprocess.check_output(
            [Compiler, "-print-sysroot"], text=True
        ).strip()
    except Exception:
        RuntimeSysroot = ""

    print(f"   STAGE SYSROOT -> {RuntimeSysroot}")

    if RuntimeSysroot and os.path.isdir(RuntimeSysroot):
        AllItems = list(Path(RuntimeSysroot).rglob("*"))
        Directories = [Item for Item in AllItems if Item.is_dir()]
        Files = [Item for Item in AllItems if Item.is_file() or Item.is_symlink()]

        for DirPath in Directories:
            RelPath = DirPath.relative_to(RuntimeSysroot)
            DstDirPath = os.path.join(Stage, RelPath)
            os.makedirs(DstDirPath, exist_ok=True)

        for FilePath in Files:
            RelPath = FilePath.relative_to(RuntimeSysroot)
            DstFilePath = os.path.join(Stage, RelPath)
            SrcFilePath = str(FilePath)

            # Ensure destination directory exists
            os.makedirs(os.path.dirname(DstFilePath), exist_ok=True)

            # Copy file normally, preserving symlinks
            shutil.copy2(SrcFilePath, DstFilePath, follow_symlinks=False)
    else:
        print("   (sysroot not available, skipping sysroot staging)")

    BootDir = os.path.join(Stage, "boot")
    os.makedirs(BootDir, exist_ok=True)
    print(f"   STAGE {os.path.basename(KernelExecutablePath)} -> /boot")
    shutil.copy2(KernelExecutablePath, BootDir)

    if BootloaderComponents:
        BootloaderLibraries = []
        for ComponentName, ComponentPath in BootloaderComponents.items():
            if ComponentName.startswith("Main:"):
                BootloaderLibraries.append(ComponentPath)

        for LibraryPath in sorted(set(BootloaderLibraries)):
            print(f"   STAGE {os.path.basename(LibraryPath)} -> /boot")
            shutil.copy2(LibraryPath, BootDir)

    GenerateGrubConfig(
        os.path.join(BootDir, "grub"),
        Config=EnvironmentObject["BuildConfig"],
        KernelName=EnvironmentObject["KernelOutputName"],
        VolumeLabelName=Volume,
    )

    if Libraries:
        LibDir = os.path.join(Stage, "usr", "lib")
        os.makedirs(LibDir, exist_ok=True)
        for Lib in Libraries:
            print(f"   STAGE {os.path.basename(Lib)} -> /usr/lib")
            shutil.copy2(Lib, LibDir)

    if Applications:
        BinDir = os.path.join(Stage, "usr", "bin")
        os.makedirs(BinDir, exist_ok=True)
        for App in Applications:
            print(f"   STAGE {os.path.basename(App)} -> /usr/bin")
            shutil.copy2(App, BinDir)

    SourceRoot = EnvironmentObject["BASEDIR"]
    for Node in ExtraFiles:
        Src = Node.srcnode().path
        Rel = os.path.relpath(Src, SourceRoot)
        Dst = os.path.join(Stage, Rel)
        if os.path.isdir(Src):
            os.makedirs(Dst, exist_ok=True)
        else:
            print(f"   STAGE {Rel}")
            os.makedirs(os.path.dirname(Dst), exist_ok=True)
            shutil.copy2(Src, Dst)

    CreateBootableIso(
        Stage,
        ImagePath,
        Volume,
        Architecture=Architecture,
        BootType=BootType,
        BootSystem=BootSystem,
        BootloaderComponents=BootloaderComponents,
    )


def BuildImageAction(*_Args, **KeywordArguments):
    Target = KeywordArguments["target"]
    Source = KeywordArguments["source"]
    EnvObj = KeywordArguments["env"]
    KernelName = EnvObj["KernelOutputName"]
    KernelExecutablePath = None

    for Src in Source:
        PathStr = str(Src)
        Base = os.path.basename(PathStr)
        if Base == KernelName or Base.startswith(KernelName + "."):
            KernelExecutablePath = PathStr
            break

    if KernelExecutablePath is None:
        raise RuntimeError("Kernel executable not found in build inputs")

    LibraryNodes = Flatten(UserLibraries)
    LibraryPaths = []
    LibrarySet = set()
    for Library in LibraryNodes:
        AbsolutePath = (
            Library.get_abspath() if hasattr(Library, "get_abspath") else str(Library)
        )
        LibraryPaths.append(AbsolutePath)
        LibrarySet.add(str(Library))

    ApplicationNodes = Flatten(UserApplications)
    ApplicationPaths = []
    ApplicationSet = set()
    for Application in ApplicationNodes:
        AbsolutePath = (
            Application.get_abspath()
            if hasattr(Application, "get_abspath")
            else str(Application)
        )
        ApplicationPaths.append(AbsolutePath)
        ApplicationSet.add(str(Application))

    BootloaderComponentNodes = EnvObj.get("BootloaderComponents", {})
    BootloaderComponentPaths = {}
    BootloaderComponentSet = set()

    for ComponentName, Component in IterBootloaderComponentNodes(
        BootloaderComponentNodes
    ):
        AbsolutePath = Component.get_abspath()
        BootloaderComponentPaths[ComponentName] = AbsolutePath
        BootloaderComponentSet.add(str(Component))
        BootloaderComponentSet.add(AbsolutePath)

    ExtraFiles = [
        Src
        for Src in Source
        if str(Src) != KernelExecutablePath
        and str(Src) not in LibrarySet
        and str(Src) not in ApplicationSet
        and str(Src) not in BootloaderComponentSet
    ]

    BuildDisk(
        str(Target[0]),
        KernelExecutablePath,
        LibraryPaths,
        ApplicationPaths,
        ExtraFiles,
        BootloaderComponentPaths,
        EnvObj,
    )


Root = Env.Dir("root")
RootFiles = GlobRecursive(Env, "*", Root)

BootloaderInputs = []
if Env.get("BootType", "grub") in ("bios", "efi"):
    for _, Component in IterBootloaderComponentNodes(
        Env.get("BootloaderComponents", {})
    ):
        BootloaderInputs.append(Component)

Inputs = [Kernel] + UserLibraries + UserApplications + RootFiles + BootloaderInputs

Out = f"valeciumos-{Env['ProjVersion']}_{Env['BuildConfig']}_{Env['BuildArch']}.iso"

Image = Env.Command(
    Out,
    Inputs,
    action=Action(BuildImageAction, "   CREATING ISO"),
    BASEDIR=Root.srcnode().path,
)

Export("Image")
