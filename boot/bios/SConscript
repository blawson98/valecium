"""
BIOS bootloader build configuration.
"""

import os
import subprocess
import sys

from SCons.Script import File, SConscript
from scripts.scons.bootloader import ConfigureBootloaderEnvironment


Import("TargetEnvironment")
Import("SourcePath")
Import("ArchitecturePath")
Import("ArchitectureConfig")
Import("BootloaderBuildConfig")
Import("Architecture")
Import("Sources")
Import("CoreFsSources")
Import("CoreFsSharedSources")
Import("CoreSources")


LinkModeByArchitecture = {
    "i686": "elf_i386",
    "x86_64": "elf_x86_64",
}

# =============================================================================
# Generated Source Files
# =============================================================================

VideoPath = os.path.join(SourcePath, "bios", "video")

MkfontPath = os.path.join(VideoPath, "mkfont.py")
FontGenC = os.path.join(VideoPath, "font_gen.c")
if os.path.exists(MkfontPath) and not os.path.exists(FontGenC):
    subprocess.run([sys.executable, MkfontPath, FontGenC], check=True)

# =============================================================================
# BIOS Source Files
# =============================================================================

CoreSources += [
    File("main.c"),
]

SConscript("video/SConscript", exports=["CoreSources"])

if Architecture == "i686":
    ArchResult = SConscript("i686/SConscript", exports=["CoreSources"])
elif Architecture == "x86_64":
    ArchResult = SConscript("x86_64/SConscript", exports=["CoreSources"])
else:
    raise RuntimeError(f"Unsupported BIOS architecture: {Architecture}")

BootSector = ArchResult["BootSector"]
CoreFsDiskSource = ArchResult["CoreFsDiskSource"]
CoreFsLinkerScript = ArchResult["CoreFsLinkerScript"]

# =============================================================================
# Stage 1 (Boot Sector) Build
# =============================================================================

BootBin = TargetEnvironment.File("boot.bin")
TargetEnvironment["BootloaderComponents"]["Stage1"] = BootBin

BootLinkerScript = TargetEnvironment.File(f"{Architecture}/boot.ld").srcnode()
BootEnvironment = TargetEnvironment.Clone()
ConfigureBootloaderEnvironment(
    BootEnvironment,
    SourcePath,
    ArchitecturePath,
    ArchitectureConfig,
    BootloaderBuildConfig,
)
BootEnvironment.AppendUnique(
    LINKFLAGS=[
        "-nostdlib",
        "-Wl,-N",
        f"-Wl,-m,{LinkModeByArchitecture[Architecture]}",
        f"-Wl,-T,{BootLinkerScript.path}",
        "-Wl,--oformat,binary",
    ]
)

BootSectorObject = BootEnvironment.Object(BootSector)
BootSectorBinary = BootEnvironment.Program(BootBin, BootSectorObject)
BootEnvironment.AddPostAction(
    BootSectorBinary,
    lambda target, source, env: (
        (_ for _ in ()).throw(
            RuntimeError(
                f"BIOS boot sector exceeds 0x1be bytes: {boot_sector_size} bytes"
            )
        )
        if (boot_sector_size := os.path.getsize(str(target[0]))) > 0x1BE
        else None
    ),
)
BootEnvironment.Depends(BootSectorBinary, BootLinkerScript)

# =============================================================================
# Stage 2 (Core) Build
# =============================================================================

CoreBin = TargetEnvironment.File("core.bin")
TargetEnvironment["BootloaderComponents"]["Stage2"] = CoreBin

CoreLinkerScript = TargetEnvironment.File(f"{Architecture}/core.ld").srcnode()
CoreEnvironment = TargetEnvironment.Clone()
ConfigureBootloaderEnvironment(
    CoreEnvironment,
    SourcePath,
    ArchitecturePath,
    ArchitectureConfig,
    BootloaderBuildConfig,
)
CoreEnvironment.AppendUnique(
    LINKFLAGS=[
        "-nostdlib",
        "-Wl,-N",
        f"-Wl,-m,{LinkModeByArchitecture[Architecture]}",
        f"-Wl,-T,{CoreLinkerScript.path}",
        "-Wl,--oformat,binary",
    ]
)
CoreEnvironment.Append(LIBS=["gcc"])
CoreEnvironment.Append(OBJPREFIX="core_")
CoreEnvironment.Append(CPPDEFINES=["CORE"])

CoreObjects = CoreEnvironment.Object(CoreSources)
CoreBinary = CoreEnvironment.Program(CoreBin, CoreObjects)
CoreEnvironment.Depends(CoreBinary, CoreLinkerScript)

# =============================================================================
# Core Filesystem Modules
# =============================================================================

CoreFs = []
if CoreFsSources:
    CoreFsEnvironment = TargetEnvironment.Clone()
    ConfigureBootloaderEnvironment(
        CoreFsEnvironment,
        SourcePath,
        ArchitecturePath,
        ArchitectureConfig,
        BootloaderBuildConfig,
    )
    CoreFsEnvironment.AppendUnique(
        LINKFLAGS=[
            "-nostdlib",
            "-Wl,-N",
            f"-Wl,-m,{LinkModeByArchitecture[Architecture]}",
            f"-Wl,-T,{CoreFsLinkerScript.path}",
            "-Wl,--oformat,binary",
        ]
    )
    CoreFsEnvironment.Append(OBJPREFIX="corefs_")
    CoreFsEnvironment.Append(LIBS=["gcc"])
    CoreFsEnvironment.Append(CPPDEFINES=["COREFS"])

    DiskObjects = CoreFsEnvironment.Object(CoreFsDiskSource)
    SharedObjects = CoreFsEnvironment.Object(CoreFsSharedSources)

    for FsSource in CoreFsSources:
        FsName = os.path.splitext(FsSource.name)[0]
        FsObjects = CoreFsEnvironment.Object(FsSource)
        FsBinary = CoreFsEnvironment.Program(
            TargetEnvironment.File(f"corefs_{FsName}.bin"),
            DiskObjects + SharedObjects + FsObjects,
        )
        CoreFsEnvironment.Depends(FsBinary, CoreFsLinkerScript)
        CoreFs.append(FsBinary)

TargetEnvironment["BootloaderComponents"]["CoreFs"] = CoreFs
